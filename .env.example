# ─────────────────────────────────────────────
# Backend (apps/api)
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# Postgres (matches docker-compose.yml)
DATABASE_URL=postgresql://signal:signal@localhost:5433/signal_watcher?schema=public

# Redis (matches docker-compose.yml)
REDIS_URL=redis://localhost:6379

# CORS — comma-separated origins allowed to call the API
CORS_ORIGINS=http://localhost:3000

# AI provider: "gemini" | "mock"
AI_PROVIDER=mock
GEMINI_API_KEY=replace-me-with-a-real-key
GEMINI_MODEL=gemini-flash-latest

# Cache TTL for AI enrichment results (seconds)
AI_CACHE_TTL_SECONDS=600

# ─────────────────────────────────────────────
# Frontend (apps/web)
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Signal Watcher
# Server-side only — used by Server Actions to call the API
API_BASE_URL=http://localhost:3001
