{
  "name": "signal-watcher",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --filter \"./apps/*\" dev",
    "build": "pnpm -r build",
    "build:shared": "pnpm --filter @signal-watcher/shared build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm run build:shared && pnpm -r typecheck",
    "test": "pnpm run build:shared && pnpm -r test",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
